# VidForge Backend Environment
# Copy this file to .env and fill in your actual keys

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# BytePlus ModelArk (Seedance) — https://console.volcengine.com/ark
SEEDANCE_API_KEY=your_seedance_api_key

# Butterbase — https://butterbase.ai
BUTTERBASE_URL=https://api.butterbase.ai/mcp
BUTTERBASE_API_KEY=your_butterbase_api_key

# Photon — https://photon.ai
PHOTON_API_KEY=your_photon_api_key
PHOTON_BASE_URL=https://api.photon.ai/v1

# TRIBE v2 sidecar (local)
TRIBE_SIDECAR_URL=http://localhost:8001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
